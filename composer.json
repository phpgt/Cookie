{
	"name": "phpgt/cookie",
	"description": "Object oriented cookie handler.",
	"license": "MIT",

	"require": {
		"php": ">=8.1"
	},

	"require-dev": {
		"phpstan/phpstan": "^2.1",
		"phpunit/phpunit": "^10.5",
		"phpmd/phpmd": "^2.15",
		"squizlabs/php_codesniffer": "^4.0"
	},

	"authors": [
		{
			"name": "Greg Bowler",
			"email": "greg.bowler@g105b.com"
		}
	],

	"autoload": {
		"psr-4": {
			"Gt\\Cookie\\": "./src"
		}
	},

	"autoload-dev": {
		"psr-4": {
			"Gt\\Cookie\\Test\\": "./test/phpunit"
		}
	},

	"scripts": {
		"phpunit": "vendor/bin/phpunit --configuration phpunit.xml",
		"phpstan": "vendor/bin/phpstan analyse --level 6 src --memory-limit 256M",
		"phpcs": "vendor/bin/phpcs src --standard=phpcs.xml",
		"phpmd": "vendor/bin/phpmd src/ text phpmd.xml",
		"test": [
			"@phpunit",
			"@phpstan",
			"@phpcs",
			"@phpmd"
		]
	},

	"funding": [
		{
			"type": "github",
			"url": "https://github.com/sponsors/phpgt"
		}
	]
}
